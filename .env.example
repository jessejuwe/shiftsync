# Database (required)
# For Neon: use pooled URL for app, direct URL for Prisma CLI
# Get both from https://console.neon.tech → Connect
DATABASE_URL="postgresql://user:password@localhost:5432/shiftsync?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/shiftsync?schema=public"

# Auth (required for NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Pusher (optional - for real-time)
PUSHER_APP_ID="1234567890"
PUSHER_KEY="pusher-key"
PUSHER_SECRET="pusher-secret"
PUSHER_CLUSTER="pusher-cluster"

# Client-side (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_PUSHER_KEY="pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="pusher-cluster"

# Schedule (optional - for shift management)
NEXT_PUBLIC_UNPUBLISH_EDIT_CUTOFF_HOURS="48"